---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ContactActions from '../components/ContactActions.astro';
import { services } from '../data/services';
import { siteInfo } from '../data/site';

const title = 'GreenCal Pressure Washing';
const description = `Residential exterior cleaning serving ${siteInfo.region}.`;
---

<BaseLayout title={title} description={description}>
  <h1>GreenCal Pressure Washing</h1>
  <p>{description}</p>
  <p>
    {siteInfo.businessName} provides residential exterior cleaning for homes in {siteInfo.region}.
  </p>
  {services.map((service) => <ServiceCard service={service} />)}
  <section>
    <h2>How It Works</h2>
    <ol>
      <li>Contact {siteInfo.businessName} by phone or email.</li>
      <li>Discuss your property and exterior cleaning needs.</li>
      <li>Schedule a visit.</li>
    </ol>
  </section>
  <ContactActions />
  <p>
    <a href="/residential-services">Residential Services</a>
    <a href="/contact-us">Contact</a>
  </p>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ContactActions from '../components/ContactActions.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ClosingCta from '../components/ClosingCta.astro';
import { servicesByCategory } from '../data/services';
import { siteInfo } from '../data/site';

const title = 'GreenCal Pressure Washing';
const description = `Residential, commercial, and multi-family exterior cleaning serving approved communities across San Diego, Orange, and Riverside Counties.`;

const residential = servicesByCategory('residential');
const commercial = servicesByCategory('commercial');
const multiFamilyHoa = servicesByCategory('multi-family-hoa');
---

<BaseLayout title={title} description={description} path="/">
  <h1>GreenCal Pressure Washing</h1>
  <p class="lede">
    {siteInfo.businessName} provides residential, commercial, and multi-family exterior cleaning
    for properties across approved Southern California communities.
  </p>
  <div class="cta-banner">
    <p>Call or email to request a quote:</p>
    <ContactActions />
  </div>

  <p class="service-area-statement">
    Serving approved communities across San Diego, Orange, and Riverside Counties. See the{' '}
    <a href="/service-areas">full service-area list</a> to check your location.
  </p>

  <section aria-labelledby="residential-heading">
    <h2 id="residential-heading">Residential Services</h2>
    {residential.map((service) => <ServiceCard service={service} />)}
    <p><a href="/residential">All residential services</a></p>
  </section>

  <section aria-labelledby="commercial-heading">
    <h2 id="commercial-heading">Commercial Services</h2>
    {commercial.map((service) => <ServiceCard service={service} />)}
    <p><a href="/commercial">All commercial services</a></p>
  </section>

  <section aria-labelledby="multi-family-hoa-heading">
    <h2 id="multi-family-hoa-heading">Multi-Family & HOA Services</h2>
    {multiFamilyHoa.map((service) => <ServiceCard service={service} />)}
    <p><a href="/multi-family-hoa">All multi-family & HOA services</a></p>
  </section>

  <HowItWorks />
  <ClosingCta />
  <nav aria-label="Related pages" class="page-links">
    <a href="/service-areas">Service Areas</a>
    <a href="/contact-us">Contact</a>
  </nav>
</BaseLayout>

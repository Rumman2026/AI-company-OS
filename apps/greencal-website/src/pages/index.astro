---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ContactActions from '../components/ContactActions.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ClosingCta from '../components/ClosingCta.astro';
import { services } from '../data/services';
import { siteInfo } from '../data/site';

const title = 'GreenCal Pressure Washing';
const description = `Residential exterior cleaning serving ${siteInfo.region}.`;
---

<BaseLayout title={title} description={description} path="/">
  <h1>GreenCal Pressure Washing</h1>
  <p class="lede">
    {siteInfo.businessName} provides residential exterior cleaning for homes in {siteInfo.region}.
  </p>
  <div class="cta-banner">
    <p>Call or email to request a quote:</p>
    <ContactActions />
  </div>
  <section aria-labelledby="services-heading">
    <h2 id="services-heading">Our Services</h2>
    {services.map((service) => <ServiceCard service={service} />)}
  </section>
  <HowItWorks />
  <ClosingCta />
  <nav aria-label="Related pages" class="page-links">
    <a href="/residential-services">Residential Services</a>
    <a href="/contact-us">Contact</a>
  </nav>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactActions from '../components/ContactActions.astro';
import { siteInfo } from '../data/site';

const title = 'Contact | GreenCal Pressure Washing';
const description = `Contact ${siteInfo.businessName} by phone or email.`;
---

<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p>{siteInfo.businessName}</p>
  <p>
    Call or email {siteInfo.businessName} to request a quote or ask a question about your
    property's exterior cleaning needs.
  </p>
  <ContactActions />
</BaseLayout>

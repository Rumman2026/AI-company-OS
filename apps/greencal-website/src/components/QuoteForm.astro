---
import ContactActions from './ContactActions.astro';
import { quoteFormServiceOptions } from '../data/quote-form-service-options';
import { COUNTIES, citiesByCounty } from '../data/cities';
import { OTHER_CITY_SLUG } from '../lib/quote-form/validation';
import type { ServiceCategory } from '../types/content';

export interface Props {
  /** Suppress the inline call/email CTA when the page already shows one nearby. */
  showContactActions?: boolean;
}

const { showContactActions = true } = Astro.props;

const SERVICE_GROUP_LABELS: Record<ServiceCategory, string> = {
  residential: 'Residential',
  commercial: 'Commercial',
  'multi-family-hoa': 'Multi-Family & HOA',
};
const serviceCategories: ServiceCategory[] = ['residential', 'commercial', 'multi-family-hoa'];
const otherServiceOptions = quoteFormServiceOptions.filter((option) => option.category === 'other');
---

<section class="quote-form-section" aria-labelledby="quote-form-heading" id="quote-form">
  <h2 id="quote-form-heading">Request a Quote</h2>
  {
    showContactActions ? (
      <>
        <p>Prefer to talk right away? You can also call or email us directly, no form required:</p>
        <ContactActions />
      </>
    ) : (
      <p>You can also call or email us directly, no form required - see above.</p>
    )
  }
  <p>
    Or fill out this form and GreenCal Pressure Washing will follow up using the contact method
    you provide.
  </p>

  <div id="quote-form-error-summary" class="form-error-summary" role="alert" tabindex="-1" hidden>
    <h3>Please fix the following:</h3>
    <ul id="quote-form-error-list"></ul>
  </div>

  <form id="quote-form-form" novalidate>
    <div class="form-field">
      <label for="qf-fullName">Full name <span aria-hidden="true">*</span></label>
      <input
        type="text"
        id="qf-fullName"
        name="fullName"
        required
        maxlength="100"
        autocomplete="name"
        aria-describedby="qf-fullName-error"
        aria-invalid="false"
      />
      <span id="qf-fullName-error" class="field-error" role="alert"></span>
    </div>

    <div class="form-field">
      <label for="qf-phone">Phone number <span aria-hidden="true">*</span></label>
      <input
        type="tel"
        id="qf-phone"
        name="phone"
        required
        maxlength="20"
        autocomplete="tel"
        aria-describedby="qf-phone-error"
        aria-invalid="false"
      />
      <span id="qf-phone-error" class="field-error" role="alert"></span>
    </div>

    <div class="form-field">
      <label for="qf-email">Email <span aria-hidden="true">*</span></label>
      <input
        type="email"
        id="qf-email"
        name="email"
        required
        maxlength="254"
        autocomplete="email"
        aria-describedby="qf-email-error"
        aria-invalid="false"
      />
      <span id="qf-email-error" class="field-error" role="alert"></span>
    </div>

    <div class="form-field">
      <label for="qf-service">Requested service <span aria-hidden="true">*</span></label>
      <select
        id="qf-service"
        name="service"
        required
        aria-describedby="qf-service-error qf-service-help"
        aria-invalid="false"
      >
        <option value="">Select a service</option>
        {
          serviceCategories.map((category) => (
            <optgroup label={SERVICE_GROUP_LABELS[category]}>
              {quoteFormServiceOptions
                .filter((option) => option.category === category)
                .map((option) => (
                  <option value={option.slug}>{option.label}</option>
                ))}
            </optgroup>
          ))
        }
        <optgroup label="Other">
          {
            otherServiceOptions.map((option) => (
              <option value={option.slug}>{option.label}</option>
            ))
          }
        </optgroup>
      </select>
      <span id="qf-service-help" class="field-help"
        >Selecting "Other Exterior Cleaning Request" means GreenCal will review whether the
        described scope is supported before confirming.</span
      >
      <span id="qf-service-error" class="field-error" role="alert"></span>
    </div>

    <div class="form-field">
      <label for="qf-city">City <span aria-hidden="true">*</span></label>
      <select
        id="qf-city"
        name="city"
        required
        aria-describedby="qf-city-error qf-city-help"
        aria-invalid="false"
      >
        <option value="">Select your city</option>
        {
          COUNTIES.map((county) => (
            <optgroup label={county}>
              {citiesByCounty(county).map((city) => (
                <option value={city.slug}>{city.name}</option>
              ))}
            </optgroup>
          ))
        }
        <option value={OTHER_CITY_SLUG}>Other / not listed here</option>
      </select>
      <span id="qf-city-help" class="field-help"
        >Don't see your city? Choose "Other / not listed here" - we'll still review your
        request.</span
      >
      <span id="qf-city-error" class="field-error" role="alert"></span>
    </div>

    <div class="form-field">
      <label for="qf-serviceLocation">Street address or ZIP code <span aria-hidden="true">*</span
        ></label>
      <input
        type="text"
        id="qf-serviceLocation"
        name="serviceLocation"
        required
        maxlength="120"
        autocomplete="street-address"
        aria-describedby="qf-serviceLocation-error qf-serviceLocation-help"
        aria-invalid="false"
      />
      <span id="qf-serviceLocation-help" class="field-help"
        >Street address, ZIP code, or nearest cross-streets - a full address is not required.</span
      >
      <span id="qf-serviceLocation-error" class="field-error" role="alert"></span>
    </div>

    <div class="form-field">
      <label for="qf-projectDescription"
        >Project description <span aria-hidden="true">*</span></label
      >
      <textarea
        id="qf-projectDescription"
        name="projectDescription"
        required
        maxlength="2000"
        rows="4"
        aria-describedby="qf-projectDescription-error qf-projectDescription-help"
        aria-invalid="false"
      ></textarea>
      <span id="qf-projectDescription-help" class="field-help"
        >Tell us about your property and what you'd like cleaned.</span
      >
      <span id="qf-projectDescription-error" class="field-error" role="alert"></span>
    </div>

    <fieldset class="form-fieldset">
      <legend>Preferred contact method (optional)</legend>
      <label class="form-radio-option">
        <input type="radio" id="qf-preferredContactMethod-phone" name="preferredContactMethod" value="phone" />
        Phone
      </label>
      <label class="form-radio-option">
        <input type="radio" id="qf-preferredContactMethod-email" name="preferredContactMethod" value="email" />
        Email
      </label>
    </fieldset>

    <div class="form-field">
      <label for="qf-preferredTiming">Preferred timing (optional)</label>
      <select id="qf-preferredTiming" name="preferredTiming">
        <option value="">No preference</option>
        <option value="as-soon-as-possible">As soon as possible</option>
        <option value="within-a-week">Within a week</option>
        <option value="within-a-month">Within a month</option>
        <option value="flexible">Flexible</option>
      </select>
    </div>

    <div class="form-field">
      <label for="qf-propertyType">Property type (optional)</label>
      <select id="qf-propertyType" name="propertyType">
        <option value="">Prefer not to say</option>
        <option value="single-family-home">Single-family home</option>
        <option value="condo-townhome">Condo / townhome</option>
        <option value="multi-family">Multi-family</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div class="form-field">
      <label for="qf-estimatedProjectSize">Estimated project size (optional)</label>
      <select id="qf-estimatedProjectSize" name="estimatedProjectSize">
        <option value="">Not sure</option>
        <option value="small">Small</option>
        <option value="medium">Medium</option>
        <option value="large">Large</option>
      </select>
    </div>

    <div class="quote-form-honeypot" aria-hidden="true">
      <label for="qf-website">Leave this field blank</label>
      <input type="text" id="qf-website" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <div class="form-field form-consent">
      <label>
        <input
          type="checkbox"
          id="qf-consent"
          name="consent"
          required
          aria-describedby="qf-consent-error"
          aria-invalid="false"
        />
        I agree that GreenCal Pressure Washing may contact me about this request.
        <span aria-hidden="true">*</span>
      </label>
      <span id="qf-consent-error" class="field-error" role="alert"></span>
    </div>

    <p id="quote-form-status" role="status" aria-live="polite" class="quote-form-status"></p>

    <button type="submit" id="quote-form-submit">Request a Quote</button>
  </form>
</section>

<script>
  import type { FieldErrors, QuoteSubmissionResult } from '../lib/quote-form/types';
  import { trackEvent } from '../lib/tracking/production';
  import { mapSubmissionResultToEvent } from '../lib/tracking/quote-form-events';

  const FORM_ID = 'quote-form-form';

  const form = document.querySelector<HTMLFormElement>('#quote-form-form');
  const errorSummary = document.querySelector<HTMLDivElement>('#quote-form-error-summary');
  const errorList = document.querySelector<HTMLUListElement>('#quote-form-error-list');
  const statusRegion = document.querySelector<HTMLParagraphElement>('#quote-form-status');
  const submitButton = document.querySelector<HTMLButtonElement>('#quote-form-submit');

  /**
   * The only place the client talks to the network. Validation and the
   * real adapter boundary live server-side (src/pages/api/quote-submit.ts
   * -> submitQuoteForm) - this just posts the raw fields and parses the
   * same typed QuoteSubmissionResult back. A network-level failure (the
   * request never reaching the server, or an unparseable response) is
   * mapped to delivery_failed locally - never fabricated success.
   */
  async function submitQuoteFormViaApi(raw: Record<string, unknown>): Promise<QuoteSubmissionResult> {
    try {
      const response = await fetch('/api/quote-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...raw, pagePath: window.location.pathname }),
      });
      const result: unknown = await response.json();
      if (
        result &&
        typeof result === 'object' &&
        'status' in result &&
        typeof (result as { status: unknown }).status === 'string'
      ) {
        return result as QuoteSubmissionResult;
      }
      return {
        status: 'delivery_failed',
        message: "We couldn't send your request. Please call or email us directly.",
      };
    } catch {
      return {
        status: 'delivery_failed',
        message: "We couldn't send your request. Please call or email us directly.",
      };
    }
  }

  if (form && errorSummary && errorList && statusRegion && submitButton) {
    let isSubmitting = false;
    let hasStarted = false;

    // "View" - the form was present on the loaded page. No PII in params.
    trackEvent({ name: 'quote_form_view', params: { pagePath: window.location.pathname, formId: FORM_ID } });

    const trackStartOnce = (): void => {
      if (hasStarted) return;
      hasStarted = true;
      trackEvent({
        name: 'quote_form_start',
        params: { pagePath: window.location.pathname, formId: FORM_ID },
      });
    };
    form.addEventListener('focusin', trackStartOnce, { once: true });

    const FIELD_IDS: Record<string, string> = {
      fullName: 'qf-fullName',
      phone: 'qf-phone',
      email: 'qf-email',
      service: 'qf-service',
      city: 'qf-city',
      serviceLocation: 'qf-serviceLocation',
      projectDescription: 'qf-projectDescription',
      consent: 'qf-consent',
      preferredContactMethod: 'qf-preferredContactMethod-phone',
      preferredTiming: 'qf-preferredTiming',
      propertyType: 'qf-propertyType',
      estimatedProjectSize: 'qf-estimatedProjectSize',
    };

    const clearErrors = (): void => {
      form.querySelectorAll<HTMLElement>('.field-error').forEach((el) => {
        el.textContent = '';
      });
      form.querySelectorAll<HTMLElement>('[aria-invalid="true"]').forEach((el) => {
        el.setAttribute('aria-invalid', 'false');
      });
      errorList.innerHTML = '';
      errorSummary.hidden = true;
    };

    const showFieldErrors = (fieldErrors: FieldErrors): void => {
      for (const [field, message] of Object.entries(fieldErrors)) {
        if (field === 'honeypot' || field === 'form') continue;
        const fieldId = FIELD_IDS[field];
        if (!fieldId) continue;

        const errorEl = document.getElementById(`${fieldId}-error`);
        if (errorEl) errorEl.textContent = message;

        const inputEl = document.getElementById(fieldId);
        if (inputEl) inputEl.setAttribute('aria-invalid', 'true');

        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${fieldId}`;
        a.textContent = message;
        li.appendChild(a);
        errorList.appendChild(li);
      }

      if (errorList.childElementCount > 0) {
        errorSummary.hidden = false;
        errorSummary.focus();
      }
    };

    const setStatus = (message: string): void => {
      statusRegion.textContent = message;
    };

    const setSubmitting = (submitting: boolean): void => {
      isSubmitting = submitting;
      submitButton.disabled = submitting;
      submitButton.textContent = submitting ? 'Sending…' : 'Request a Quote';
    };

    const lockFormAfterSuccess = (): void => {
      form.setAttribute('data-submitted', 'true');
      Array.from(form.elements).forEach((el) => {
        (
          el as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | HTMLButtonElement
        ).disabled = true;
      });
    };

    const handleResult = (result: QuoteSubmissionResult): void => {
      clearErrors();

      trackEvent(
        mapSubmissionResultToEvent(result, {
          pagePath: window.location.pathname,
          formId: FORM_ID,
        }),
      );

      if (result.status === 'validation_failed') {
        if (result.fieldErrors.honeypot) {
          // A trusted-boundary spam signal, not a real user error - never
          // explain honeypot rejection specifically.
          setStatus("We couldn't process that submission. Please call or email us directly.");
          return;
        }
        showFieldErrors(result.fieldErrors);
        setStatus('Please fix the highlighted fields below.');
        return;
      }

      if (result.status === 'success') {
        setStatus('Thank you - your request was received. We will contact you soon.');
        lockFormAfterSuccess();
        return;
      }

      // pending_configuration and delivery_failed both surface their own
      // honest, pre-written message via the live status region.
      setStatus(result.message);
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSubmitting || form.hasAttribute('data-submitted')) return;

      setSubmitting(true);
      setStatus('Sending your request…');

      const formData = new FormData(form);
      const raw = {
        fullName: String(formData.get('fullName') ?? ''),
        phone: String(formData.get('phone') ?? ''),
        email: String(formData.get('email') ?? ''),
        service: String(formData.get('service') ?? ''),
        city: String(formData.get('city') ?? ''),
        serviceLocation: String(formData.get('serviceLocation') ?? ''),
        projectDescription: String(formData.get('projectDescription') ?? ''),
        consent: formData.get('consent') !== null,
        preferredContactMethod: String(formData.get('preferredContactMethod') ?? ''),
        preferredTiming: String(formData.get('preferredTiming') ?? ''),
        propertyType: String(formData.get('propertyType') ?? ''),
        estimatedProjectSize: String(formData.get('estimatedProjectSize') ?? ''),
        honeypot: String(formData.get('website') ?? ''),
      };

      try {
        const result = await submitQuoteFormViaApi(raw);
        handleResult(result);
      } finally {
        if (!form.hasAttribute('data-submitted')) {
          setSubmitting(false);
        }
      }
    });
  }
</script>

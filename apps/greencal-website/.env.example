# Public, browser-safe identifier only - never a secret. Astro exposes
# PUBLIC_-prefixed variables to client-side code (see astro.config.mjs).
#
# Unset by default. Leaving this empty keeps all tracking safely inactive -
# see src/lib/tracking/README.md for the full activation checklist.
#
# Format: GTM-XXXXXXX (this example value is a placeholder, not a real id).
PUBLIC_GTM_CONTAINER_ID=

# --- Stage 4A: quote-delivery backend (server-only - never PUBLIC_-prefixed) ---
#
# All five variables below are required together. If any one is missing or
# malformed, the /api/quote-submit endpoint falls back to the honest
# pending_configuration response - see src/lib/quote-form/README.md for the
# full activation checklist and src/lib/quote-form/supabase-schema.sql for
# the required Supabase table setup. Configure real values only in Vercel's
# project environment variables (and, for local testing, an untracked
# .env file) - never commit real values here.

# GreenCal-owned Supabase project URL. Format: https://<project-ref>.supabase.co
SUPABASE_URL=

# Supabase service-role key for this project. Server-only - grants full
# database access bypassing Row Level Security. Never expose to the
# browser. Configure in Vercel's server-only environment variables.
SUPABASE_SERVICE_ROLE_KEY=

# GreenCal-owned Resend API key. Server-only.
RESEND_API_KEY=

# Verified Resend sender identity. Format: "GreenCal Pressure Washing <noreply@greencalpressurewashing.com>"
# or a plain verified address - must belong to a domain verified in Resend.
RESEND_FROM_ADDRESS=

# Approved notification recipient for new quote leads.
NOTIFICATION_RECIPIENT_EMAIL=greencaliforniacorporation@gmail.com

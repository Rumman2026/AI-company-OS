{
  "name": "ai-company-os",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.12.0",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" run dev",
    "build": "pnpm -r --parallel --filter \"./apps/*\" run build",
    "lint": "pnpm -r --filter \"@ai-company-os/**\" run lint",
    "format": "pnpm -r --filter \"@ai-company-os/**\" run format",
    "typecheck": "pnpm -r --filter \"@ai-company-os/**\" run typecheck",
    "prepare": "husky install",
    "workspace:status": "pnpm --version",
    "bootstrap": "pnpm install"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^40.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.0.0",
    "tsx": "^4.10.0",
    "typescript": "^5.7.0"
  }
}
